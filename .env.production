# Storefront canonical URL (used for metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.ddaily.co.ke

# Express API base — must include /api in production
NEXT_PUBLIC_API_URL=https://d-daily-e-commerce-backend.onrender.com/api

# Paystack public key
# Set this to your Paystack public key for frontend usage.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Optional: ISR revalidation interval in seconds for product/catalog pages
NEXT_PUBLIC_REVALIDATE_SECONDS=300
